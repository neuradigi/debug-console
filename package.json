{
  "name": "@neuradigi/debug-console",
  "version": "0.1.0",
  "description": "Framework-agnostic in-app console overlay that mirrors console.* and uncaught errors into a floating debug panel. Works in Angular, React, Vue, Svelte, or plain HTML — zero runtime dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "console",
    "logging",
    "logger",
    "debug",
    "devtools",
    "overlay",
    "web-component",
    "custom-element",
    "angular",
    "react",
    "vue",
    "svelte"
  ],
  "author": "Neuradigi Technologies <hello@neuradigi.com> (https://neuradigi.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neuradigi/debug-console.git"
  },
  "homepage": "https://github.com/neuradigi/debug-console#readme",
  "bugs": {
    "url": "https://github.com/neuradigi/debug-console/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
